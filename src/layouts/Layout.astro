---
// Base HTML shell for the Lentago Labs site.
// Links the canonical design tokens (public/design-system/styles.css, which
// @imports the self-hosted fonts + token files) and the small set of global
// styles the design relies on. Page content (the ported sections) comes
// through the default slot.
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Lentago Labs — Production that shows up when the need does.',
  description = 'Lentago Labs — infrastructure operations consulting. Twenty-five years of production: platform engineering, cost & posture audits, incident & on-call, CI/CD & supply chain. Build it, break it, operate it.',
} = Astro.props;

// Canonical origin for absolute URLs (og:url, og:image). The site is a single
// page served at the apex; keep this a literal so the static build needs no
// runtime config.
const SITE = 'https://lentago.dev';
const ogImage = `${SITE}/og-cover.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`${SITE}/`} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Open Graph — social share cards (Slack, iMessage, LinkedIn, Facebook) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lentago Labs" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${SITE}/`} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Lentago Labs — Production that shows up when the need does." />

    <!-- Twitter / X large summary card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="stylesheet" href="/design-system/styles.css" />
    <style is:global>
      html {
        scroll-behavior: smooth;
      }
      html,
      body {
        margin: 0;
        background: var(--color-bg);
      }
      body {
        overflow-x: hidden;
      }
      a:focus-visible,
      button:focus-visible,
      input:focus-visible,
      select:focus-visible,
      textarea:focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
      }
      ::selection {
        background: var(--color-accent);
        color: var(--color-on-accent);
      }

      /* Nav link hover re-expressed as CSS — the design prototype used
         onMouseEnter/onMouseLeave, which don't run on this static (no
         hydration) site. The active item stays gold via .ll-navlink--active. */
      .ll-navlink {
        color: var(--fg2);
        transition: color 120ms var(--ease-standard);
      }
      .ll-navlink:hover {
        color: var(--color-accent);
      }
      .ll-navlink--active {
        color: var(--color-accent);
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
